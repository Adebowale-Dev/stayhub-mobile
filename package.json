{
  "name": "stayhub-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node ./scripts/expo-android.js start",
    "start:clear": "node ./scripts/expo-android.js start -c",
    "android": "node ./scripts/expo-android.js run:android",
    "android:clear": "node ./scripts/expo-android.js start -c --android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "bundle:android": "expo export --platform android --output-dir .expo-export-test"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
